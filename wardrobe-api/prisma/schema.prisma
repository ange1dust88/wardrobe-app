generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Category {
  top
  bottom
  shoes
  accessory
  dress
  outerwear
  headwear
}

enum Temperature {
  warm
  cool
  neutral
}

enum Brightness {
  light
  medium
  dark
}

enum Saturation {
  muted
  soft
  vivid
}

enum WardrobeRole {
  core
  tonal
  pop
}

enum Pattern {
  solid
  subtle_pattern
  bold_pattern
  graphic
  texture_only
}

enum SeasonPalette {
  spring
  summer
  autumn
  winter
  universal
}

enum Vibe {
  casual
  sporty
  minimalist
  urban
  workwear
  romantic
  edgy
  vintage
  classic
  relaxed
}

enum Formality {
  loungewear
  casual
  smart_casual
  formal
}

enum Fit {
  slim
  regular
  relaxed
  oversized
}

enum SeasonWear {
  spring
  summer
  autumn
  winter
}

model Item {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId   String?
  name     String
  category Category
  subType  String?
  imageUrl String?

  hex         String
  accentHex   String?
  hue         Int
  temperature Temperature
  brightness  Brightness
  saturation  Saturation
  isNeutral   Boolean

  wardrobeRole               WardrobeRole
  pattern                    Pattern
  formality                  Formality?
  fit                        Fit?
  vibe                       Vibe[]
  seasonPaletteCompatibility SeasonPalette[]
  seasonWear                 SeasonWear[]

  @@index([userId, category])
}

model Outfit {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String?
  name      String
  itemIds   String[]
  folderId  String?
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
}

model Folder {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String?
  name      String
  outfits   Outfit[]

  @@index([userId])
}

model Feedback {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String?
  email     String?
  message   String
  page      String?
}

enum Who {
  men
  women
  mix
}

enum Climate {
  cold
  mild
  hot
}

enum Undertone {
  warm
  cool
}

model UserProfile {
  userId      String          @id
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  who         Who?
  climate     Climate?
  palettes    SeasonPalette[]
  hair        Int?
  eyes        Int?
  skin        Int?
  undertone   Undertone?
  onboardedAt DateTime?
}
