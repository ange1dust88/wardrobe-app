# --- Database (Supabase Postgres) ---
# Pooled connection used by the app (pgBouncer, port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma for schema changes (port 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Supabase project ---
# Used for auth (JWT verification) and image storage.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Service role key — server-only, never expose to the client. Needed for uploads.
SUPABASE_SERVICE_ROLE_KEY="PASTE_SERVICE_ROLE_KEY"
# Storage bucket for item photos.
SUPABASE_BUCKET="items"

# --- Server ---
# Port to listen on (defaults to 3000 if unset). Dev uses 3100.
PORT=3100
# Comma-separated allowed web origins for CORS. Leave empty to allow any (dev only).
WEB_ORIGIN="http://localhost:3101"
