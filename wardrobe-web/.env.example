# The API now lives in this same Next.js app (app/api/*) — no separate backend.

# --- Database (Supabase Postgres) ---
# Pooled connection used by the app (pgBouncer, port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma for schema changes (port 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Supabase project ---
# Server-side URL for JWT verification + image storage (defaults to
# NEXT_PUBLIC_SUPABASE_URL if unset).
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Service role key — server-only, never expose to the client. Needed for
# image uploads and account deletion.
SUPABASE_SERVICE_ROLE_KEY="PASTE_SERVICE_ROLE_KEY"
# Storage bucket for item photos.
SUPABASE_BUCKET="items"

# --- Supabase project (browser auth) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY="PASTE_ANON_KEY"

# --- Product analytics (PostHog) — optional ---
# Leave the key empty to disable analytics entirely (no-op, nothing loads).
NEXT_PUBLIC_POSTHOG_KEY=""
# Ingestion host: US "https://us.i.posthog.com" or EU "https://eu.i.posthog.com".
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
